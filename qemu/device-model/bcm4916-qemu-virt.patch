# BCM4916 / GT-BE98 control-plane + datapath wiring for QEMU 10.0.0.
# Apply inside the qemu-10.0.0 source tree on the build host:
#   patch -p1 < bcm4916-qemu-virt.patch
# Then copy device-model/bcm4916_sf2.c     to hw/net/bcm4916_sf2.c
#       and device-model/bcm4916_runner.c  to hw/net/bcm4916_runner.c
# and rebuild (configure --target-list=aarch64-softmmu; ninja qemu-system-aarch64).
# Run with the env var QEMU_BCM4916=1 to enable the device on -machine virt.
#
# Stage 3 change vs the Stage 2 patch: create_bcm4916() now instantiates the
# real TYPE_BCM4916_RUNNER datapath device (DT "brcm,bcm4916-runner") at the
# rdpa window 0x82000000, wires its queue0 (SPI 75) + fpm (SPI 107) IRQs, emits
# the matching FDT node, points the SF2 DSA CPU/IMP port at it (ethernet=&runner)
# instead of the stand-in Cadence GEM, and attaches the runner as a NIC so a
# -netdev backend can inject/emit frames.

--- a/hw/arm/virt.c	2025-04-22 20:26:10.000000000 +0000
+++ b/hw/arm/virt.c	2026-06-19 21:00:00.000000000 +0000
@@ -2103,6 +2103,233 @@
     }
 }
 
+
+/*
+ * BCM4916 / GT-BE98 control-plane + datapath model (gt-be98-open-ethernet).
+ * Enabled when the environment variable QEMU_BCM4916 is set. Instantiates the
+ * SF2 switch core + UNIMAC MDIO master + XRDP "Runner" CPU-conduit at fixed
+ * MMIO bases, and emits matching FDT nodes into the auto-generated device tree
+ * so a stock mainline kernel (+ driver/mainline-patches + driver/runner) binds
+ * bcm_sf2/b53 + mdio-bcm-unimac + phylib + the open Runner conduit without an
+ * external -dtb.
+ *
+ * The Runner netdev is the DSA CPU-port conduit (replaces the Stage 2 Cadence
+ * GEM stand-in). Attach a backend with e.g.
+ *   -netdev user,id=rnet -nic ... (the runner NIC binds the first -netdev/-nic)
+ * or explicitly via the auto-created NIC.
+ */
+#define BCM4916_SF2_BASE     0x0a800000
+#define BCM4916_MDIO_BASE    0x0a900000
+#define BCM4916_RUNNER_BASE  0x82000000UL   /* rdpa window (ABI 1.1) */
+#define BCM4916_RUNNER_SIZE  0x00caf004UL
+#define BCM4916_RUNNER_Q0    75             /* GIC SPI queue0 (RX) */
+#define BCM4916_RUNNER_FPM   107            /* GIC SPI fpm */
+
+static void create_bcm4916(VirtMachineState *vms)
+{
+    MachineState *ms = MACHINE(vms);
+    DeviceState *sf2, *mdio, *runner;
+    char *node, *mdio_node, *phy_node;
+    uint32_t mdio_ph, phy2_ph, phy9_ph, phy21_ph;
+    uint32_t runner_ph;
+    const char sf2_compat[] = "brcm,bcm4916-switch";
+    const char mdio_compat[] = "brcm,unimac-mdio";
+    const char runner_compat[] = "brcm,bcm4916-runner";
+
+    if (!getenv("QEMU_BCM4916")) {
+        return;
+    }
+
+    /* --- SF2 switch core --- */
+    sf2 = qdev_new("bcm4916-sf2");
+    sysbus_realize_and_unref(SYS_BUS_DEVICE(sf2), &error_fatal);
+    sysbus_mmio_map(SYS_BUS_DEVICE(sf2), 0, BCM4916_SF2_BASE);
+
+    /* --- UNIMAC MDIO master --- */
+    mdio = qdev_new("bcm4916-mdio");
+    sysbus_realize_and_unref(SYS_BUS_DEVICE(mdio), &error_fatal);
+    sysbus_mmio_map(SYS_BUS_DEVICE(mdio), 0, BCM4916_MDIO_BASE);
+
+    /* --- XRDP Runner CPU-conduit (DSA conduit netdev) --- */
+    runner = qdev_new("bcm4916-runner");
+    /*
+     * Peer the Runner NIC with a -netdev id=rnet if present (the Stage 3
+     * datapath test backend); otherwise fall back to a default -nic match.
+     */
+    if (qemu_find_netdev("rnet")) {
+        qdev_prop_set_string(runner, "netdev", "rnet");
+    } else {
+        qemu_configure_nic_device(runner, true, NULL);
+    }
+    sysbus_realize_and_unref(SYS_BUS_DEVICE(runner), &error_fatal);
+    sysbus_mmio_map(SYS_BUS_DEVICE(runner), 0, BCM4916_RUNNER_BASE);
+    sysbus_connect_irq(SYS_BUS_DEVICE(runner), 0,
+                       qdev_get_gpio_in(vms->gic, BCM4916_RUNNER_Q0));
+    sysbus_connect_irq(SYS_BUS_DEVICE(runner), 1,
+                       qdev_get_gpio_in(vms->gic, BCM4916_RUNNER_FPM));
+
+    /* --- FDT: MDIO bus + PHY children --- */
+    mdio_ph = qemu_fdt_alloc_phandle(ms->fdt);
+    phy2_ph = qemu_fdt_alloc_phandle(ms->fdt);
+    phy9_ph = qemu_fdt_alloc_phandle(ms->fdt);
+    phy21_ph = qemu_fdt_alloc_phandle(ms->fdt);
+
+    mdio_node = g_strdup_printf("/mdio@%x", BCM4916_MDIO_BASE);
+    qemu_fdt_add_subnode(ms->fdt, mdio_node);
+    qemu_fdt_setprop(ms->fdt, mdio_node, "compatible",
+                     mdio_compat, sizeof(mdio_compat));
+    qemu_fdt_setprop_sized_cells(ms->fdt, mdio_node, "reg",
+                                 2, BCM4916_MDIO_BASE, 2, 0x8);
+    qemu_fdt_setprop_string(ms->fdt, mdio_node, "reg-names", "mdio");
+    qemu_fdt_setprop_cell(ms->fdt, mdio_node, "#address-cells", 1);
+    qemu_fdt_setprop_cell(ms->fdt, mdio_node, "#size-cells", 0);
+    qemu_fdt_setprop_cell(ms->fdt, mdio_node, "phandle", mdio_ph);
+
+    phy_node = g_strdup_printf("%s/ethernet-phy@2", mdio_node);
+    qemu_fdt_add_subnode(ms->fdt, phy_node);
+    qemu_fdt_setprop_cell(ms->fdt, phy_node, "reg", 2);
+    qemu_fdt_setprop_cell(ms->fdt, phy_node, "phandle", phy2_ph);
+    g_free(phy_node);
+
+    phy_node = g_strdup_printf("%s/ethernet-phy@9", mdio_node);
+    qemu_fdt_add_subnode(ms->fdt, phy_node);
+    qemu_fdt_setprop_cell(ms->fdt, phy_node, "reg", 9);
+    qemu_fdt_setprop_cell(ms->fdt, phy_node, "phandle", phy9_ph);
+    g_free(phy_node);
+
+    phy_node = g_strdup_printf("%s/ethernet-phy@15", mdio_node); /* 21 = 0x15 */
+    qemu_fdt_add_subnode(ms->fdt, phy_node);
+    qemu_fdt_setprop_cell(ms->fdt, phy_node, "reg", 21);
+    qemu_fdt_setprop_cell(ms->fdt, phy_node, "phandle", phy21_ph);
+    g_free(phy_node);
+
+    /* --- FDT: Runner CPU-conduit node (the DSA conduit) --- */
+    runner_ph = qemu_fdt_alloc_phandle(ms->fdt);
+    {
+        char *rnode = g_strdup_printf("/runner@%lx",
+                                      (unsigned long)BCM4916_RUNNER_BASE);
+        qemu_fdt_add_subnode(ms->fdt, rnode);
+        qemu_fdt_setprop(ms->fdt, rnode, "compatible",
+                         runner_compat, sizeof(runner_compat));
+        qemu_fdt_setprop_sized_cells(ms->fdt, rnode, "reg",
+                                     2, BCM4916_RUNNER_BASE,
+                                     2, BCM4916_RUNNER_SIZE);
+        qemu_fdt_setprop(ms->fdt, rnode, "reg-names", "rdpa", sizeof("rdpa"));
+        qemu_fdt_setprop(ms->fdt, rnode, "interrupt-names",
+                         "queue0\0fpm", sizeof("queue0\0fpm"));
+        qemu_fdt_setprop_cell(ms->fdt, rnode, "interrupt-parent",
+                              vms->gic_phandle);
+        qemu_fdt_setprop_cells(ms->fdt, rnode, "interrupts",
+                               GIC_FDT_IRQ_TYPE_SPI, BCM4916_RUNNER_Q0,
+                               GIC_FDT_IRQ_FLAGS_LEVEL_HI,
+                               GIC_FDT_IRQ_TYPE_SPI, BCM4916_RUNNER_FPM,
+                               GIC_FDT_IRQ_FLAGS_LEVEL_HI);
+        /* QEMU Runner model => skip the proprietary microcode load */
+        qemu_fdt_setprop(ms->fdt, rnode, "brcm,runner-emulated", NULL, 0);
+        qemu_fdt_setprop_cell(ms->fdt, rnode, "phandle", runner_ph);
+        g_free(rnode);
+    }
+
+    /* --- FDT: SF2 switch node with 6 reg regions + ports --- */
+    node = g_strdup_printf("/ethernet-switch@%x", BCM4916_SF2_BASE);
+    qemu_fdt_add_subnode(ms->fdt, node);
+    qemu_fdt_setprop(ms->fdt, node, "compatible",
+                     sf2_compat, sizeof(sf2_compat));
+    {
+        uint64_t b = BCM4916_SF2_BASE;
+        qemu_fdt_setprop_sized_cells(ms->fdt, node, "reg",
+            2, b + 0x00000, 2, 0x40000,   /* core */
+            2, b + 0x40000, 2, 0x00110,   /* reg */
+            2, b + 0x40340, 2, 0x00030,   /* intrl2_0 */
+            2, b + 0x40380, 2, 0x00030,   /* intrl2_1 */
+            2, b + 0x40600, 2, 0x00034,   /* fcb */
+            2, b + 0x40800, 2, 0x00208);  /* acb */
+    }
+    qemu_fdt_setprop(ms->fdt, node, "reg-names",
+        "core\0reg\0intrl2_0\0intrl2_1\0fcb\0acb",
+        sizeof("core\0reg\0intrl2_0\0intrl2_1\0fcb\0acb"));
+    qemu_fdt_setprop_cell(ms->fdt, node, "brcm,num-gphy", 5);
+    qemu_fdt_setprop_cell(ms->fdt, node, "interrupt-parent", vms->gic_phandle);
+    qemu_fdt_setprop_cells(ms->fdt, node, "interrupts",
+                           GIC_FDT_IRQ_TYPE_SPI, 180, GIC_FDT_IRQ_FLAGS_LEVEL_HI,
+                           GIC_FDT_IRQ_TYPE_SPI, 181, GIC_FDT_IRQ_FLAGS_LEVEL_HI);
+    qemu_fdt_setprop_cells(ms->fdt, node, "dsa,member", 0, 0);
+
+    {
+        char *ports = g_strdup_printf("%s/ports", node);
+        char *port;
+        qemu_fdt_add_subnode(ms->fdt, ports);
+        qemu_fdt_setprop_cell(ms->fdt, ports, "#address-cells", 1);
+        qemu_fdt_setprop_cell(ms->fdt, ports, "#size-cells", 0);
+
+        /* port@1 -> eth2 internal EGPHY @ mdio addr 2 (first-light target) */
+        port = g_strdup_printf("%s/port@1", ports);
+        qemu_fdt_add_subnode(ms->fdt, port);
+        qemu_fdt_setprop_cell(ms->fdt, port, "reg", 1);
+        qemu_fdt_setprop_string(ms->fdt, port, "label", "eth2");
+        qemu_fdt_setprop_string(ms->fdt, port, "phy-mode", "gmii");
+        qemu_fdt_setprop_cell(ms->fdt, port, "phy-handle", phy2_ph);
+        g_free(port);
+
+        /* port@5 -> eth0 external 10G @ mdio addr 9 */
+        port = g_strdup_printf("%s/port@5", ports);
+        qemu_fdt_add_subnode(ms->fdt, port);
+        qemu_fdt_setprop_cell(ms->fdt, port, "reg", 5);
+        qemu_fdt_setprop_string(ms->fdt, port, "label", "eth0");
+        qemu_fdt_setprop_string(ms->fdt, port, "phy-mode", "gmii");
+        qemu_fdt_setprop_cell(ms->fdt, port, "phy-handle", phy9_ph);
+        g_free(port);
+
+        /* port@7 -> RGMII (satisfies bcm_sf2 BCM4908 crossbar_setup) */
+        port = g_strdup_printf("%s/port@7", ports);
+        qemu_fdt_add_subnode(ms->fdt, port);
+        qemu_fdt_setprop_cell(ms->fdt, port, "reg", 7);
+        qemu_fdt_setprop_string(ms->fdt, port, "phy-mode", "rgmii");
+        {
+            char *fl7 = g_strdup_printf("%s/fixed-link", port);
+            qemu_fdt_add_subnode(ms->fdt, fl7);
+            qemu_fdt_setprop_cell(ms->fdt, fl7, "speed", 1000);
+            qemu_fdt_setprop(ms->fdt, fl7, "full-duplex", NULL, 0);
+            g_free(fl7);
+        }
+        g_free(port);
+
+        /* port@8 -> CPU/IMP port; conduit = the Runner netdev */
+        port = g_strdup_printf("%s/port@8", ports);
+        qemu_fdt_add_subnode(ms->fdt, port);
+        qemu_fdt_setprop_cell(ms->fdt, port, "reg", 8);
+        qemu_fdt_setprop_string(ms->fdt, port, "phy-mode", "internal");
+        qemu_fdt_setprop_cell(ms->fdt, port, "ethernet", runner_ph);
+        {
+            char *fl = g_strdup_printf("%s/fixed-link", port);
+            qemu_fdt_add_subnode(ms->fdt, fl);
+            qemu_fdt_setprop_cell(ms->fdt, fl, "speed", 1000);
+            qemu_fdt_setprop(ms->fdt, fl, "full-duplex", NULL, 0);
+            g_free(fl);
+        }
+        g_free(port);
+        g_free(ports);
+    }
+
+    info_report("bcm4916: SF2 @0x%x, MDIO @0x%x, Runner @0x%lx mapped + FDT emitted",
+                BCM4916_SF2_BASE, BCM4916_MDIO_BASE,
+                (unsigned long)BCM4916_RUNNER_BASE);
+
+    g_free(node);
+    g_free(mdio_node);
+}
+
 static void machvirt_init(MachineState *machine)
 {
     VirtMachineState *vms = VIRT_MACHINE(machine);
@@ -2438,6 +2665,8 @@
 
     create_platform_bus(vms);
 
+    create_bcm4916(vms);
+
     if (machine->nvdimms_state->is_enabled) {
         const struct AcpiGenericAddress arm_virt_nvdimm_acpi_dsmio = {
             .space_id = AML_AS_SYSTEM_MEMORY,
--- a/hw/net/meson.build	2025-04-22 20:26:11.000000000 +0000
+++ b/hw/net/meson.build	2026-06-19 21:00:00.000000000 +0000
@@ -72,3 +72,7 @@
 system_ss.add(files('rocker/rocker-hmp-cmds.c'))
 
 subdir('can')
+
+# BCM4916 / GT-BE98 control-plane + datapath model (gt-be98-open-ethernet)
+system_ss.add(when: 'CONFIG_ARM_VIRT', if_true: files('bcm4916_sf2.c'))
+system_ss.add(when: 'CONFIG_ARM_VIRT', if_true: files('bcm4916_runner.c'))
