/*
 * gt-be98.dts - ASUS GT-BE98 (Broadcom BCM4916 / "bcm6813")
 *
 * Board-level device tree for the gt-be98-open-ethernet effort.
 *
 * REBASED (2026-06) onto the UPSTREAM mainline SoC dtsi:
 *   - dts/bcm6813.dtsi      : VERBATIM copy of mainline
 *                             arch/arm64/boot/dts/broadcom/bcmbca/bcm6813.dtsi
 *                             (CPUs/PSCI, GIC-400, arch timer, PMU, clocks,
 *                              PL011 uart0, hsspi, nand). BCM4916 == BCM6813 die.
 *   - dts/bcm4916-enet.dtsi : our open Ethernet/switch/MDIO/PHY/MAC/Runner
 *                             overlay (none of this is in upstream).
 *   - this file             : GT-BE98 board specifics (model/memory/chosen) +
 *                             enabling the four wired ports and their PHYs.
 *
 * When built in-tree, replace the bcm6813.dtsi include with the in-tree path;
 * the vendored copy exists so this builds standalone with cpp+dtc.
 *
 * Topology (all [FDT]+[SDK] confirmed, see re-notes/bcm4916-regmap.md and the
 * 4916 SDK GT-BE98.dts):
 *   wan = eth0 : SF2 port#5, XPORT -> external 10G BCM84891 @ MDIO 9
 *   lan = eth1 : SF2 port#6, XPORT -> serdes0, 10GBase-R fixed-link @ MDIO 7
 *   lan = eth2 : SF2 port#1, UNIMAC gmii -> internal EGPHY @ MDIO 2 (1G)
 *   lan = eth3 : SF2 port#7, XPORT -> serdes1 @ MDIO 8 -> ext PHY @ MDIO 21
 *
 * PUBLIC-SAFE: no real unit MAC, no internal hosts/IPs/paths.
 */

/dts-v1/;

/*
 * BOOT-CRITICAL reserved firmware region (1 MiB @ phys 0).
 * The bootloader leaves ATF/BL31 (the EL3 secure monitor that services PSCI
 * SMC calls, incl. CPU_ON for SMP bringup), the secondary-CPU boot trampoline
 * and the PMC firmware/log resident in low DRAM. Mainline upstream bcm6813.dtsi
 * declares NO reservation, so a full memory@0 = <0 0x80000000> lets Linux clobber
 * ATF -> the first PSCI CPU_ON faults very early (no console). The vendor SDK
 * reserves exactly this via /memreserve/ in kernel/dts/boot_rsvdmem.dtsi:
 *   0x00000:0x04000  16K  secondary-CPU boot
 *   0x04000:0xC0000 752K  ATF/BL31 secure monitor   (ATF FIT load/entry = 0x4000)
 *   0xC0000:0xF0000 192K  PMC firmware
 *   0xF0000:0x100000 64K  PMC firmware log
 * Non-SMC / no-OPTEE build (CONFIG_BRCM_SMC_BASED/BOOT and CONFIG_OPTEE all
 * unset in the 6813 .config) => BOOT_RESERVED = ALWAYS_RESERVED = 0x100000.
 * Source: src-rt-5.04behnd.4916 kernel/dts/boot_rsvdmem.dtsi +
 *         bootloaders/armtf/.../bcm_mem_reserve.h + brcm_simple_aarch64_atf.its
 */
/memreserve/ 0x0000000000000000 0x0000000000100000;

#include "bcm6813.dtsi"
#include "bcm4916-enet.dtsi"

/ {
	model = "ASUS GT-BE98";
	compatible = "asus,gt-be98", "brcm,bcm4916", "brcm,bcm6813", "brcm,bcmbca";

	aliases {
		serial0 = &uart0;
		ethernet0 = &unimac;
	};

	chosen {
		stdout-path = "serial0:115200n8";
		/* console=ttyAMA0,115200 [SDK GT-BE98 bootargs] */
	};

	/*
	 * GT-BE98 ships 2 GiB DDR4 [SDK GT-BE98.dts memcfg: BP_DDR_TOTAL_SIZE_2048MB].
	 * Base 0x0; the bootloader passes the authoritative size/reservations.
	 */
	memory@0 {
		device_type = "memory";
		reg = <0x0 0x0 0x0 0x80000000>;	/* 2 GiB [SDK GT-BE98 BP_DDR_TOTAL_SIZE_2048MB] */
	};

	/*
	 * Same firmware region as the /memreserve/ above, also exposed as a
	 * no-map reserved-memory node so the kernel reserved-memory framework
	 * keeps it out of the linear map / page allocator. no-map => never
	 * mapped cacheable, never handed to Linux (vendor keeps ATF/PMC here).
	 */
	reserved-memory {
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		atf_pmc@0 {
			reg = <0x0 0x0 0x0 0x00100000>;	/* 1 MiB: bootcpu+ATF/BL31+PMC [SDK boot_rsvdmem.dtsi] */
			no-map;
		};
	};
};

&uart0 {
	status = "okay";
};

/* ---- NAND (boot device) — OBSERVABILITY LIFELINE -------------------------- *
 * Upstream bcm6813.dtsi ships nand_controller@1800 status="disabled", so a
 * mainline boot has NO MTD device at all -> no UBI -> the /data breadcrumb the
 * trial initramfs writes is impossible (it silently falls back to a tmpfs log
 * that dies with the kernel). That is why trial cycles 01-03 produced ZERO
 * persistent signal regardless of whether mainline reached userspace.
 *
 * Enable it. mainline brcmnand (CONFIG_MTD_NAND_BRCMNAND_BCMBCA=y) binds
 * "brcm,nand-bcm63138"/"brcm,brcmnand-v7.1" and INHERITS the ECC config the
 * bootloader programmed into the controller — so, exactly like the stock GT-BE98
 * DT (which also omits nand-ecc-* on nandcs@0), we specify no ECC properties.
 * Geometry confirmed on silicon: 2 KiB page, 108 B OOB, 128 KiB erase,
 * on-flash BBT.  The fixed-partitions node reproduces the bootloader's
 * mtdparts (loader 2 MiB @0, image 253 MiB @0x200000) so /proc/mtd carries the
 * "image" label the init greps for to ubiattach the UBI that holds /data.
 * [silicon: /proc/mtd + /proc/device-tree/periph/nand + stock cmdline mtdparts]
 */
&nand_controller {
	brcm,wp-not-connected;		/* [upstream bcm96813.dts] */
	status = "okay";
};

&nandcs {
	nand-on-flash-bbt;	/* [stock GT-BE98 nandcs@0] */
	brcm,nand-ecc-use-strap;	/* ECC layout from NAND strap/bootloader — REQUIRED for
					 * mainline brcmnand to bind; the DTSI node carries no ECC
					 * config, the board dts must. [upstream bcm96813.dts] */

	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* mirrors bootloader mtdparts=brcmnand.0:2097152(loader),265289728@2097152(image) */
		partition@0 {
			label = "loader";
			reg = <0x0 0x200000>;	/* 2 MiB U-Boot — read-only, NEVER written */
			read-only;
		};
		partition@200000 {
			label = "image";
			reg = <0x200000 0xfce0000>;	/* 265289728 B: the single UBI (bootfs/rootfs/data) */
		};
	};
};

/* ---- MDIO PHYs ------------------------------------------------------------ */

&mdio {
	status = "okay";
};

/* eth2: internal 1G EGPHY @ MDIO 2 (first-light target). [FDT][SDK] */
&phy_gphy1 {
	status = "okay";
};

/*
 * eth0: external 10G copper PHY (BCM84891) @ MDIO 9 on XPORT mac0.
 * BCM84891 binds mainline drivers/net/phy/bcm84881.c (compatible by PHY id,
 * but add an explicit ethernet-phy-id for clarity). PHY id 0x359050e1 [recon].
 * TODO: confirm bcm84881 driver drives the 84891 variant; the FDT also needs
 * ethphytop xphy0-enabled to release this PHY from reset.
 */
&phy_xphy {
	compatible = "ethernet-phy-id3590.50e1",	/* [recon] BCM84891 */
		     "ethernet-phy-ieee802.3-c45";
	status = "okay";
};

/*
 * eth1: serdes0 10GBase-R, fixed link (no addressable copper PHY).
 * Stock: phy-fixed + config-xfi="10GBase-R" [SDK GT-BE98 phy_serdes0].
 */
&phy_serdes0 {
	/* phy-fixed; config-xfi "10GBase-R" [SDK] - modeled via port fixed-link */
	status = "okay";
};

/*
 * eth3: serdes1 @ MDIO 8 cascaded to an external multigig PHY @ MDIO 21.
 * Add the cascade PHY node on the bus. PHY id 0x35905081 [recon].
 */
&mdio {
	phy_cascade1: ethernet-phy@21 {
		reg = <21>;
		compatible = "ethernet-phy-id3590.5081",	/* [recon] ext multigig PHY */
			     "ethernet-phy-ieee802.3-c45";
		status = "okay";
	};
};

&phy_serdes1 {
	phy-handle = <&phy_cascade1>;	/* serdes1 -> cascade ext PHY @21 [FDT][SDK] */
	status = "okay";
};

/* ---- Runner CPU conduit --------------------------------------------------- */

/*
 * Enable the XRDP Runner CPU-port conduit (the DSA master netdev that fronts
 * switch0's CPU/IMP port). brcm,runner-emulated is inherited from the overlay
 * so this binds against the QEMU Runner model with no proprietary microcode.
 */
&runner {
	status = "okay";
};

/* ---- Switch ports --------------------------------------------------------- */

&switch0 {
	status = "okay";
};

/* eth2 = port#1, internal GPHY, 1G. [FDT][SDK] */
&switch0 {
	ports {
		port@1 {
			label = "eth2";
			status = "okay";
		};

		/* eth0 = port#5, external 10G copper (WAN). [FDT][SDK] */
		port@5 {
			label = "eth0";
			status = "okay";
		};

		/*
		 * eth1 = port#6, serdes0 10GBase-R fixed link. [FDT][SDK]
		 * No addressable copper PHY -> use fixed-link instead of phy-handle.
		 */
		port@6 {
			/delete-property/ phy-handle;
			label = "eth1";
			phy-mode = "10gbase-r";
			status = "okay";
			fixed-link {
				speed = <10000>;
				full-duplex;
			};
		};

		/* eth3 = port#7, serdes1 -> cascade ext multigig PHY @21. [FDT][SDK] */
		port@7 {
			label = "eth3";
			status = "okay";
		};
	};
};

/* ---- Top-level PHY mux / EGPHY power ------------------------------------- */

/*
 * Release the internal EGPHYs and the external xphy from reset.
 * [SDK GT-BE98: &ethphytop { xphy0-enabled; status="okay"; }]
 */
&ethphytop {
	/* xphy0-enabled [SDK] */
	status = "okay";
};

&egphy {
	status = "okay";
};

/* ---- MAC cores ------------------------------------------------------------ */

&unimac {
	/*
	 * Device WAN MAC placeholder. The real per-unit MAC is provisioned by the
	 * bootloader (board NVRAM/OTP); do NOT hardcode a real unit MAC.
	 * 60:cf:84 is the ASUS OUI; the low 3 bytes are zeroed here on purpose.
	 */
	local-mac-address = [60 cf 84 00 00 00];	/* PLACEHOLDER - bootloader overrides */
	status = "okay";
};

&xport {
	status = "okay";
};
