From 4e7aab5fc113a3593f021ce6f09f37e3beb10fa4 Mon Sep 17 00:00:00 2001
From: be98 <be98@local>
Date: Fri, 19 Jun 2026 16:50:45 +0000
Subject: [PATCH] net: dsa: bcm_sf2: add brcm,bcm4916-switch binding

Bind the integrated SF2 switch on the Broadcom BCM4916 (ASUS GT-BE98).
The SF2 core register interface and the port-7 crossbar are identical to
the BCM4908, so bcm_sf2_4916_data reuses bcm_sf2_4908_reg_offsets and the
4908 crossbar/RGMII/LED/port-override paths; only the chip type differs
(BCM4916_DEVICE_ID, which selects the BCM4916 b53 chip row).
---
 drivers/net/dsa/bcm_sf2.c | 24 +++++++++++++++++++++++-
 1 file changed, 23 insertions(+), 1 deletion(-)

diff --git a/drivers/net/dsa/bcm_sf2.c b/drivers/net/dsa/bcm_sf2.c
index de3efa3ce..78ace9b96 100644
--- a/drivers/net/dsa/bcm_sf2.c
+++ b/drivers/net/dsa/bcm_sf2.c
@@ -36,6 +36,7 @@ static u16 bcm_sf2_reg_rgmii_cntrl(struct bcm_sf2_priv *priv, int port)
 {
 	switch (priv->type) {
 	case BCM4908_DEVICE_ID:
+	case BCM4916_DEVICE_ID:
 		switch (port) {
 		case 7:
 			return REG_RGMII_11_CNTRL;
@@ -75,6 +76,7 @@ static u16 bcm_sf2_reg_led_base(struct bcm_sf2_priv *priv, int port)
 
 	switch (priv->type) {
 	case BCM4908_DEVICE_ID:
+	case BCM4916_DEVICE_ID:
 		switch (port) {
 		case 3:
 			return REG_LED_3_CNTRL;
@@ -98,6 +100,7 @@ static u32 bcm_sf2_port_override_offset(struct bcm_sf2_priv *priv, int port)
 {
 	switch (priv->type) {
 	case BCM4908_DEVICE_ID:
+	case BCM4916_DEVICE_ID:
 	case BCM7445_DEVICE_ID:
 		return port == 8 ? CORE_STS_OVERRIDE_IMP :
 				   CORE_STS_OVERRIDE_GMIIP_PORT(port);
@@ -518,6 +521,7 @@ static void bcm_sf2_crossbar_setup(struct bcm_sf2_priv *priv)
 	reg = reg_readl(priv, REG_CROSSBAR);
 	switch (priv->type) {
 	case BCM4908_DEVICE_ID:
+	case BCM4916_DEVICE_ID:
 		shift = CROSSBAR_BCM4908_INT_P7 * priv->num_crossbar_ext_bits;
 		reg &= ~(mask << shift);
 		if (0) /* FIXME */
@@ -871,7 +875,8 @@ static void bcm_sf2_sw_mac_link_up(struct phylink_config *config,
 
 	reg = LINK_STS;
 	if (port == 8) {
-		if (priv->type == BCM4908_DEVICE_ID)
+		if (priv->type == BCM4908_DEVICE_ID ||
+		    priv->type == BCM4916_DEVICE_ID)
 			reg |= GMII_SPEED_UP_2G;
 		reg |= MII_SW_OR;
 	} else {
@@ -1298,6 +1303,20 @@ static const struct bcm_sf2_of_data bcm_sf2_4908_data = {
 	.num_crossbar_ext_bits = 2,
 };
 
+/*
+ * BCM4916 (ASUS GT-BE98 etc.): same SF2 core register interface and crossbar
+ * as BCM4908; only the chip type differs (selects the BCM4916 b53 chip row).
+ * Reuses bcm_sf2_4908_reg_offsets verbatim.
+ */
+static const struct bcm_sf2_of_data bcm_sf2_4916_data = {
+	.type		= BCM4916_DEVICE_ID,
+	.core_reg_align	= 0,
+	.reg_offsets	= bcm_sf2_4908_reg_offsets,
+	.num_cfp_rules	= 256,
+	.num_crossbar_int_ports = 2,
+	.num_crossbar_ext_bits = 2,
+};
+
 /* Register offsets for the SWITCH_REG_* block */
 static const u16 bcm_sf2_7445_reg_offsets[] = {
 	[REG_SWITCH_CNTRL]	= 0x00,
@@ -1349,6 +1368,9 @@ static const struct of_device_id bcm_sf2_of_match[] = {
 	{ .compatible = "brcm,bcm4908-switch",
 	  .data = &bcm_sf2_4908_data
 	},
+	{ .compatible = "brcm,bcm4916-switch",
+	  .data = &bcm_sf2_4916_data
+	},
 	{ .compatible = "brcm,bcm7445-switch-v4.0",
 	  .data = &bcm_sf2_7445_data
 	},
-- 
2.47.3

